source("~/.active-rstudio-document", echo = TRUE)
---
title: ""
library(ggplot2)
df1 <- data.frame(
densidad = c(4, 8, 12, 4, 8, 12),
WUEg = c(20, 22.5, 23.5, 26, 26, 26),
ambiente = c("Con buena oferta hídrica", "Con buena oferta hídrica", "Con buena oferta hídrica",
"Restricción hídrica", "Restricción hídrica", "Restricción hídrica")
)
p1 <- ggplot(df1, aes(densidad, WUEg, group = ambiente, color = ambiente)) +
geom_line(linewidth = 1.4) +
geom_point(size = 4) +
scale_x_continuous(breaks = c(4, 8, 12)) +
labs(
title = "Más densidad no siempre mejora la eficiencia hídrica",
subtitle = "La respuesta depende del agua disponible durante el período crítico",
x = "Densidad (plantas m⁻²)",
y = "Eficiencia de uso del agua"
) +
theme_ciencia_campo()
theme_ciencia_campo <- function() {
theme_minimal(base_size = 18) +
theme(
plot.title = element_text(face = "bold", size = 24, hjust = 0),
plot.subtitle = element_text(size = 14, color = "gray30", hjust = 0),
axis.title = element_text(face = "bold"),
axis.text = element_text(color = "black"),
panel.grid.minor = element_blank(),
panel.grid.major.x = element_blank(),
legend.position = "top",
legend.title = element_blank(),
plot.margin = margin(20, 25, 20, 25)
)
}
df1 <- data.frame(
densidad = c(4, 8, 12, 4, 8, 12),
WUEg = c(20, 22.5, 23.5, 26, 26, 26),
ambiente = c("Con buena oferta hídrica", "Con buena oferta hídrica", "Con buena oferta hídrica",
"Restricción hídrica", "Restricción hídrica", "Restricción hídrica")
)
p1 <- ggplot(df1, aes(densidad, WUEg, group = ambiente, color = ambiente)) +
geom_line(linewidth = 1.4) +
geom_point(size = 4) +
scale_x_continuous(breaks = c(4, 8, 12)) +
labs(
title = "Más densidad no siempre mejora la eficiencia hídrica",
subtitle = "La respuesta depende del agua disponible durante el período crítico",
x = "Densidad (plantas m⁻²)",
y = "Eficiencia de uso del agua"
) +
theme_ciencia_campo()
p1
ggsave("ciencia_maiz_agua.png", p1, width = 10, height = 6.7, dpi = 300)
library(patchwork)
df2a <- data.frame(
tratamiento = c("HDN", "LDW"),
valor = c(100, 130)
)
df2b <- data.frame(
tratamiento = c("HDN", "LDW"),
valor = c(1500, 1500)
)
pa <- ggplot(df2a, aes(tratamiento, valor)) +
geom_col(width = 0.65) +
labs(
title = "Flujo instantáneo de CO₂",
x = NULL, y = NULL
) +
theme_ciencia_campo() +
theme(legend.position = "none")
pb <- ggplot(df2b, aes(tratamiento, valor)) +
geom_col(width = 0.65) +
labs(
title = "CO₂ acumulado en campaña",
x = NULL, y = NULL
) +
theme_ciencia_campo() +
theme(legend.position = "none")
p2 <- pa + pb +
plot_annotation(
title = "Más respiración instantánea no implica más emisiones acumuladas",
subtitle = "El arreglo espacial modifica el microambiente del suelo"
)
p2
